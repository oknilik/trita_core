{
  "name": "trita",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "check": "pnpm type-check && pnpm lint",
    "postinstall": "prisma generate",
    "seed:assessment": "npx tsx scripts/seed-assessment.ts",
    "seed:org-team": "npx tsx scripts/seed-org-team.ts",
    "seed:blocks": "npx tsx scripts/seed-recommendation-blocks.ts",
    "pregen:outputs": "npx tsx scripts/pre-generate-outputs.ts",
    "pregen:outputs:haiku3": "npx tsx scripts/pre-generate-outputs.ts --provider anthropic --model claude-3-haiku-20240307 --concurrency 4",
    "pregen:outputs:haiku3:quality": "npx tsx scripts/pre-generate-outputs.ts --provider anthropic --model claude-3-haiku-20240307 --rewrite-model claude-3-haiku-20240307 --rewrite-max-attempts 1 --min-quality-score 80 --concurrency 4",
    "pregen:outputs:fast": "npx tsx scripts/pre-generate-outputs.ts --provider openai --model gpt-4.1-mini --concurrency 8",
    "audit:outputs": "npx tsx scripts/audit-generated-outputs.ts",
    "audit:outputs:hu": "npx tsx scripts/audit-generated-outputs.ts --locale hu --test-type HEXACO --limit 200 --min-score 78"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@clerk/nextjs": "^6.32.0",
    "@prisma/client": "6.6.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "framer-motion": "^12.30.0",
    "gray-matter": "^4.0.3",
    "next": "16.1.6",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "reading-time": "^1.5.0",
    "resend": "^6.9.1",
    "stripe": "^20.4.1",
    "svix": "^1.36.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "6.6.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
