generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS - Research Study Types
// ============================================

enum TestType {
  HEXACO
}

enum RelationshipType {
  FRIEND
  COLLEAGUE
  FAMILY
  PARTNER
  OTHER
}

enum InvitationStatus {
  PENDING
  COMPLETED
  EXPIRED
  CANCELED
}

enum UserRole {
  INDIVIDUAL
  ORG_ADMIN
  ORG_MEMBER
}

enum ScoreRange {
  LOW
  MED
  HIGH
}

// ============================================
// MODELS
// ============================================

model UserProfile {
  id        String   @id @default(cuid())
  clerkId   String?  @unique
  email     String?
  username  String?
  deleted   Boolean  @default(false)
  locale    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Demographic data (onboarding)
  birthYear   Int?
  gender      String?
  country     String?
  onboardedAt DateTime?

  // Research study fields
  testType           TestType?
  testTypeAssignedAt DateTime?
  consentedAt        DateTime?

  // Role (default: INDIVIDUAL)
  role      UserRole @default(INDIVIDUAL)

  assessmentResults    AssessmentResult[]
  assessmentDraft      AssessmentDraft?
  sentInvitations      ObserverInvitation[] @relation("InviterInvitations")
  receivedInvitations  ObserverInvitation[] @relation("ObserverInvitations")
  satisfactionFeedback SatisfactionFeedback?
  researchSurvey       ResearchSurvey?
  featureInterests     FeatureInterest[]

  // Team layer (KKV)
  ownedTeams       Team[]       @relation("TeamOwner")
  teamMemberships  TeamMember[]

  // Organization layer (KKV)
  ownedOrgs      Organization[]       @relation("OrgOwner")
  orgMemberships OrganizationMember[]

  // Candidate hiring layer
  managedCandidates CandidateInvite[] @relation("ManagedCandidates")
}

model AssessmentDraft {
  id            String   @id @default(cuid())
  userProfileId String   @unique
  testType      TestType
  answers       Json     // Record<number, number> — questionId → value
  currentPage   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userProfile UserProfile @relation(fields: [userProfileId], references: [id])
}

model AssessmentResult {
  id            String   @id @default(cuid())
  userProfileId String?
  scores        Json
  createdAt     DateTime @default(now())

  // Research study fields
  testType         TestType?
  isSelfAssessment Boolean   @default(true)

  userProfile       UserProfile?        @relation(fields: [userProfileId], references: [id])
  dimensionFeedback DimensionFeedback[]

  @@index([userProfileId])
}

// Observer invitation for peer assessment
model ObserverInvitation {
  id            String           @id @default(cuid())
  token         String           @unique @default(cuid())
  inviterId     String
  observerProfileId String?
  observerEmail String?
  observerName  String?
  testType      TestType
  status        InvitationStatus @default(PENDING)
  expiresAt          DateTime
  createdAt          DateTime         @default(now())
  completedAt        DateTime?
  reminderCount      Int              @default(0)
  lastReminderSentAt DateTime?

  inviter    UserProfile         @relation("InviterInvitations", fields: [inviterId], references: [id])
  observer   UserProfile?        @relation("ObserverInvitations", fields: [observerProfileId], references: [id])
  assessment ObserverAssessment?
  draft      ObserverDraft?

  @@index([inviterId])
  @@index([observerProfileId])
  @@index([token])
}

// Draft state for in-progress observer assessments
model ObserverDraft {
  id               String   @id @default(cuid())
  invitationId     String   @unique
  phase            String   @default("assessment")
  relationshipType String
  knownDuration    String
  answers          Json
  currentPage      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  invitation ObserverInvitation @relation(fields: [invitationId], references: [id])
}

// Observer's assessment of the inviter
model ObserverAssessment {
  id               String           @id @default(cuid())
  invitationId     String           @unique
  relationshipType RelationshipType
  knownDuration    String // "LT_1", "1_3", "3_5", "5P"
  scores           Json
  confidence       Int? // 1-5: observer's self-rated certainty (research quality filter)
  createdAt        DateTime         @default(now())

  invitation ObserverInvitation @relation(fields: [invitationId], references: [id])
}

// Merged post-results research survey (replaces SatisfactionFeedback in UI)
model ResearchSurvey {
  id                 String   @id @default(cuid())
  userProfileId      String   @unique
  createdAt          DateTime @default(now())

  selfAccuracy          Int      // 1-5: how well they recognized themselves
  priorTest             String   // "mbti" | "bigfive" | "other" | "none"
  positionLevel         String?  // "junior" | "middle" | "senior" | "independent" — employed only
  studyField            String?  // "business" | "stem" | "humanities" | "health" | "other" — student only
  industry              String?  // sector — employed/student
  motivation            String   // comma-separated: selfknowledge, career, study, recommended, curiosity
  sharingIntent         String   // comma-separated: manager, hr, colleagues, friends, nobody
  feedbackSources       String?  // comma-separated: manager, peers, reports, clients, none — employed only
  has360Process         String?  // "yes" | "no" | "unknown" — employed only
  personalityImportance Int?     // 1-5: how important is personality at work
  observerUsefulness    Int?     // 1-5, only if observer feedback exists

  userProfile UserProfile @relation(fields: [userProfileId], references: [id])
}

// Satisfaction feedback for research comparison
model SatisfactionFeedback {
  id                         String   @id @default(cuid())
  userProfileId              String   @unique
  agreementScore             Int // 1-5 (😕😐🙂😊🤩) - "Mennyire ismertél magadra?"
  observerFeedbackUsefulness Int? // 1-5 (😕😐🙂😊🤩) - Optional: usefulness of observer feedback
  siteUsefulness             Int? // 1-5 (😕😐🙂😊🤩) - Optional: overall site usefulness
  freeformFeedback           String?
  interestedInUpdates        Boolean @default(false)
  createdAt                  DateTime @default(now())

  userProfile UserProfile @relation(fields: [userProfileId], references: [id])
}

// Dimension-level feedback for accuracy assessment
model DimensionFeedback {
  id                String   @id @default(cuid())
  assessmentResultId String
  dimensionCode     String   // "H", "E", "X", "A", "C", "O"
  accuracyRating    Int      // 1-5 (😕😐🙂😊🤩)
  comment           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  assessmentResult AssessmentResult @relation(fields: [assessmentResultId], references: [id], onDelete: Cascade)

  @@unique([assessmentResultId, dimensionCode])
  @@index([assessmentResultId])
}

// Upcoming feature interest — fake door validation
model FeatureInterest {
  id            String   @id @default(cuid())
  userProfileId String
  featureKey    String   // "team" | "comm" | "360"
  createdAt     DateTime @default(now())

  userProfile UserProfile @relation(fields: [userProfileId], references: [id])

  @@unique([userProfileId, featureKey])
  @@index([featureKey])
}

// ============================================
// TEAM LAYER (KKV)
// ============================================

model Team {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  orgId     String?
  createdAt DateTime @default(now())

  owner            UserProfile        @relation("TeamOwner", fields: [ownerId], references: [id])
  org              Organization?      @relation(fields: [orgId], references: [id], onDelete: SetNull)
  members          TeamMember[]
  pendingInvites   TeamPendingInvite[]
  candidateInvites CandidateInvite[]

  @@index([ownerId])
  @@index([orgId])
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     String   @default("member") // "member" | "admin"
  joinedAt DateTime @default(now())

  team Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user UserProfile @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

// Pending team invites for users who haven't registered yet
model TeamPendingInvite {
  id        String   @id @default(cuid())
  teamId    String
  email     String
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, email])
  @@index([email])
}

// ============================================
// CANDIDATE / HIRING LAYER
// ============================================

model CandidateInvite {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  managerId   String
  teamId      String?
  email       String?
  name        String?
  position    String?
  status      String    @default("PENDING")   // PENDING | COMPLETED | EXPIRED
  testType    String    @default("HEXACO")
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  manager UserProfile      @relation("ManagedCandidates", fields: [managerId], references: [id])
  team    Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  result  CandidateResult?

  @@index([managerId])
  @@index([token])
  @@index([teamId])
}

model CandidateResult {
  id        String   @id @default(cuid())
  inviteId  String   @unique
  testType  String
  scores    Json
  createdAt DateTime @default(now())

  invite CandidateInvite @relation(fields: [inviteId], references: [id])
}

// ============================================
// ORGANIZATION LAYER (KKV)
// ============================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  status    String   @default("ACTIVE") // "ACTIVE" | "INACTIVE" | "PENDING_SETUP"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner          UserProfile                @relation("OrgOwner", fields: [ownerId], references: [id])
  members        OrganizationMember[]
  pendingInvites OrganizationPendingInvite[]
  teams          Team[]
  subscription   Subscription?

  @@index([ownerId])
}

model Subscription {
  id                   String    @id @default(cuid())
  orgId                String    @unique
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  status               String    @default("trialing")
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model OrganizationMember {
  id       String   @id @default(cuid())
  orgId    String
  userId   String
  role     String   @default("ORG_MEMBER") // "ORG_ADMIN" | "ORG_MANAGER" | "ORG_MEMBER"
  joinedAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user UserProfile  @relation(fields: [userId], references: [id])

  @@unique([orgId, userId])
  @@unique([userId])
  @@index([orgId])
  @@index([userId])
}

model OrganizationPendingInvite {
  id        String   @id @default(cuid())
  orgId     String
  email     String
  role      String   @default("ORG_MEMBER") // "ORG_ADMIN" | "ORG_MANAGER" | "ORG_MEMBER"
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email])
  @@index([email])
}
