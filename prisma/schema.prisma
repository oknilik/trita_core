generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS - Research Study Types
// ============================================

enum TestType {
  HEXACO
  HEXACO_MODIFIED
  BIG_FIVE
}

enum RelationshipType {
  FRIEND
  COLLEAGUE
  FAMILY
  PARTNER
  OTHER
}

enum InvitationStatus {
  PENDING
  COMPLETED
  EXPIRED
  CANCELED
}

enum UserRole {
  INDIVIDUAL
  COACH
  ORG_ADMIN
  ORG_MEMBER
}

enum CoachRelationshipStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum ScoreRange {
  LOW
  MED
  HIGH
}

// ============================================
// MODELS
// ============================================

model UserProfile {
  id        String   @id @default(cuid())
  clerkId   String?  @unique
  email     String?
  username  String?
  deleted   Boolean  @default(false)
  locale    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Demographic data (onboarding)
  birthYear   Int?
  gender      String?
  education   String?
  occupation  String?
  occupationStatus String?
  workSchedule String?
  companySize String?
  studyLevel String?
  unemploymentDuration String?
  country     String?
  onboardedAt DateTime?

  // Research study fields
  testType           TestType?
  testTypeAssignedAt DateTime?
  consentedAt        DateTime?

  // Role (default: INDIVIDUAL, set to COACH for coach accounts)
  role      UserRole @default(INDIVIDUAL)

  assessmentResults    AssessmentResult[]
  assessmentDraft      AssessmentDraft?
  sentInvitations      ObserverInvitation[] @relation("InviterInvitations")
  receivedInvitations  ObserverInvitation[] @relation("ObserverInvitations")
  satisfactionFeedback SatisfactionFeedback?
  researchSurvey       ResearchSurvey?
  featureInterests     FeatureInterest[]

  // Coach layer
  coachProfile              CoachProfile?
  coachClientRelationships  CoachClientRelationship[] @relation("CoachRelationships")
  clientCoachRelationships  CoachClientRelationship[] @relation("ClientRelationships")
  generatedOutputsAsCoach   GeneratedOutput[]         @relation("CoachOutputs")
  generatedOutputsAsClient  GeneratedOutput[]         @relation("ClientOutputs")
}

model AssessmentDraft {
  id            String   @id @default(cuid())
  userProfileId String   @unique
  testType      TestType
  answers       Json     // Record<number, number> — questionId → value
  currentPage   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userProfile UserProfile @relation(fields: [userProfileId], references: [id])
}

model AssessmentResult {
  id            String   @id @default(cuid())
  userProfileId String?
  scores        Json
  createdAt     DateTime @default(now())

  // Research study fields
  testType         TestType?
  isSelfAssessment Boolean   @default(true)

  userProfile       UserProfile?        @relation(fields: [userProfileId], references: [id])
  dimensionFeedback DimensionFeedback[]

  @@index([userProfileId])
}

// Observer invitation for peer assessment
model ObserverInvitation {
  id            String           @id @default(cuid())
  token         String           @unique @default(cuid())
  inviterId     String
  observerProfileId String?
  observerEmail String?
  observerName  String?
  testType      TestType
  status        InvitationStatus @default(PENDING)
  expiresAt          DateTime
  createdAt          DateTime         @default(now())
  completedAt        DateTime?
  reminderCount      Int              @default(0)
  lastReminderSentAt DateTime?

  inviter    UserProfile         @relation("InviterInvitations", fields: [inviterId], references: [id])
  observer   UserProfile?        @relation("ObserverInvitations", fields: [observerProfileId], references: [id])
  assessment ObserverAssessment?
  draft      ObserverDraft?

  @@index([inviterId])
  @@index([observerProfileId])
  @@index([token])
}

// Draft state for in-progress observer assessments
model ObserverDraft {
  id               String   @id @default(cuid())
  invitationId     String   @unique
  phase            String   @default("assessment")
  relationshipType String
  knownDuration    String
  answers          Json
  currentPage      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  invitation ObserverInvitation @relation(fields: [invitationId], references: [id])
}

// Observer's assessment of the inviter
model ObserverAssessment {
  id               String           @id @default(cuid())
  invitationId     String           @unique
  relationshipType RelationshipType
  knownDuration    String // "LT_1", "1_3", "3_5", "5P"
  scores           Json
  confidence       Int? // 1-5: observer's self-rated certainty (research quality filter)
  createdAt        DateTime         @default(now())

  invitation ObserverInvitation @relation(fields: [invitationId], references: [id])
}

// Merged post-results research survey (replaces SatisfactionFeedback in UI)
model ResearchSurvey {
  id                 String   @id @default(cuid())
  userProfileId      String   @unique
  createdAt          DateTime @default(now())

  selfAccuracy          Int      // 1-5: how well they recognized themselves
  priorTest             String   // "mbti" | "bigfive" | "other" | "none"
  positionLevel         String?  // "junior" | "middle" | "senior" | "independent" — employed only
  studyField            String?  // "business" | "stem" | "humanities" | "health" | "other" — student only
  industry              String?  // sector — employed/student
  motivation            String   // comma-separated: selfknowledge, career, study, recommended, curiosity
  sharingIntent         String   // comma-separated: manager, hr, colleagues, friends, nobody
  feedbackSources       String?  // comma-separated: manager, peers, reports, clients, none — employed only
  has360Process         String?  // "yes" | "no" | "unknown" — employed only
  personalityImportance Int?     // 1-5: how important is personality at work
  observerUsefulness    Int?     // 1-5, only if observer feedback exists

  userProfile UserProfile @relation(fields: [userProfileId], references: [id])
}

// Satisfaction feedback for research comparison
model SatisfactionFeedback {
  id                         String   @id @default(cuid())
  userProfileId              String   @unique
  agreementScore             Int // 1-5 (😕😐🙂😊🤩) - "Mennyire ismertél magadra?"
  observerFeedbackUsefulness Int? // 1-5 (😕😐🙂😊🤩) - Optional: usefulness of observer feedback
  siteUsefulness             Int? // 1-5 (😕😐🙂😊🤩) - Optional: overall site usefulness
  freeformFeedback           String?
  interestedInUpdates        Boolean @default(false)
  createdAt                  DateTime @default(now())

  userProfile UserProfile @relation(fields: [userProfileId], references: [id])
}

// Dimension-level feedback for accuracy assessment
model DimensionFeedback {
  id                String   @id @default(cuid())
  assessmentResultId String
  dimensionCode     String   // "H", "E", "X", "A", "C", "O" (HEXACO) or "O", "C", "E", "A", "N" (BIG_FIVE)
  accuracyRating    Int      // 1-5 (😕😐🙂😊🤩)
  comment           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  assessmentResult AssessmentResult @relation(fields: [assessmentResultId], references: [id], onDelete: Cascade)

  @@unique([assessmentResultId, dimensionCode])
  @@index([assessmentResultId])
}

// Upcoming feature interest — fake door validation
model FeatureInterest {
  id            String   @id @default(cuid())
  userProfileId String
  featureKey    String   // "team" | "comm" | "360"
  createdAt     DateTime @default(now())

  userProfile UserProfile @relation(fields: [userProfileId], references: [id])

  @@unique([userProfileId, featureKey])
  @@index([featureKey])
}

// ============================================
// COACH LAYER
// ============================================

// Extended profile for coach accounts
model CoachProfile {
  id            String   @id @default(cuid())
  userProfileId String   @unique
  bio           String?
  specializations Json?  // string[] e.g. ["leadership", "career", "team-dynamics"]
  maxClientSlots  Int    @default(10)
  verifiedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userProfile UserProfile @relation(fields: [userProfileId], references: [id])
}

// Coach ↔ Client relationship
model CoachClientRelationship {
  id        String                  @id @default(cuid())
  coachId   String
  clientId  String
  status    CoachRelationshipStatus @default(ACTIVE)
  startedAt DateTime                @default(now())
  endedAt   DateTime?

  coach  UserProfile @relation("CoachRelationships", fields: [coachId], references: [id])
  client UserProfile @relation("ClientRelationships", fields: [clientId], references: [id])

  @@unique([coachId, clientId])
  @@index([coachId])
  @@index([clientId])
}

// Seed-elt intervenció blokkok dimenzió tartományokhoz
// Ezekből épül a coach recommendation engine
model RecommendationBlock {
  id            String    @id @default(cuid())
  dimensionCode String    // "H" | "E" | "X" | "A" | "C" | "O" | "N"
  scoreRange    ScoreRange
  deltaFlag     String?   // "SELF_HIGH_OBS_LOW" | "SELF_LOW_OBS_HIGH" | "ALIGNED" | null
  testType      String    @default("ALL") // "HEXACO" | "BIG_FIVE" | "ALL"
  locale        String    @default("hu")  // "hu" | "en" | "de"
  content       Json      // { title: string, bullets: string[], deepDive: string, actionItems: string[] }
  createdAt     DateTime  @default(now())

  @@index([dimensionCode, scoreRange])
  @@index([locale])
}

// Cache-elt AI-generált coach output-ok
// cacheKey = testType:H-h:E-m:X-l:...:delta-H+2:...
model GeneratedOutput {
  id        String   @id @default(cuid())
  coachId   String
  clientId  String
  cacheKey  String   @unique // determinisztikus kulcs a profil kombinációból
  content   String   // markdown szöveg
  model     String   @default("claude-sonnet-4-6")
  hitCount  Int      @default(0)
  createdAt DateTime @default(now())

  coach  UserProfile @relation("CoachOutputs", fields: [coachId], references: [id])
  client UserProfile @relation("ClientOutputs", fields: [clientId], references: [id])

  @@index([coachId])
  @@index([clientId])
}
